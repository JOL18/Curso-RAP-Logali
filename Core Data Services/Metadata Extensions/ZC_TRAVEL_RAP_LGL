@UI: { headerInfo: { typeName: 'Travel',
                     typeNamePlural: 'Travels',
                     title: { type: #STANDARD,
                              value: 'TravelID' } },
       presentationVariant: [{ sortOrder: [{ by: 'TravelID',
                                             direction: #DESC }],
                               visualizations: [{ type: #AS_LINEITEM  }] }]
 }

annotate entity ZC_TRAVEL_RAP_LGL with
{
  @UI.facet: [{ id:'TravelMasterData',
                purpose: #STANDARD,
                type: #IDENTIFICATION_REFERENCE,
                label: 'Travel Master Data',
                position: 10 },
              { hidden: true }]
  TravelUUID;

  @UI: { lineItem: [{ position: 10,
                      importance: #HIGH,
                      label: 'Travel ID' },
                    { type: #FOR_ACTION,
                      dataAction: 'acceptTravel',
                      label: 'Accept Travel',
                      position: 10 },
                    { type: #FOR_ACTION,
                      dataAction: 'rejectTravel',
                      label: 'Reject Travel',
                      position: 20 },
                    { type: #FOR_ACTION,
                      dataAction: 'deductDiscount',
                      label: 'Discount',
                      position: 30 }   ],
    selectionField: [{ position: 10 }],
    identification: [{ position: 10}] }
  TravelID;

  @UI: { lineItem: [{ position: 20,
                   importance: #HIGH }],
      selectionField: [{ position: 20 }],
    identification: [{ position: 20}] }
  //Ayuda de busqueda
  @Consumption.valueHelpDefinition: [{ entity: { name: '/DMO/I_Agency_StdVH',
                                                 element: 'AgencyID' },
                                      useForValidation: true }]
  AgencyID;

  @UI: { lineItem: [{ position: 30,
                      importance: #HIGH,
                      label: 'Customer ID' }],
         selectionField: [{ position: 30 }] }
    //Ayuda de busqueda
  @Consumption.valueHelpDefinition: [{ entity: { name: '/DMO/I_Customer_StdVH',
                                                 element: 'CustomerID' },
                                       useForValidation: true }]
  CustomerID;

  @UI.lineItem: [{ position: 40,
                   importance: #MEDIUM }]
  @UI.identification: [{ position: 40 }]
  BeginDate;

  @UI.lineItem: [{ position: 50,
                   importance: #MEDIUM,
                   label: 'EndDate' }]
  @UI.identification: [{ position: 50 }]
  EndDate;

  @UI.lineItem: [{ position: 60,
                   importance: #MEDIUM,
                   label: 'Booking Fee' }]
  @UI.identification: [{ position: 60 }]
  BookingFee;

  @UI.lineItem: [{ position: 70,
                   importance: #HIGH,
                   label: 'Total Price' }]
  @UI.identification: [{ position: 70 }]
  TotalPrice;

  @UI.lineItem: [{ position: 80,
                   importance: #HIGH,
                   label: 'CurrencyCode' }]
  @UI.identification: [{ position: 80 }]
    //Ayuda de busqueda
  @Consumption.valueHelpDefinition: [{ entity: { name: 'I_CurrencyStdVH',
                                                 element: 'Currency' },
                                       useForValidation: true }]
  CurrencyCode;

  @UI : { lineItem: [{ position: 90,
                       importance: #LOW,
                       label: 'Status ' }
                       ] ,
          selectionField: [{ position: 90 }],
          identification: [{ position: 90 }],
          textArrangement: #TEXT_ONLY }
  @Consumption.valueHelpDefinition: [{ entity: { name: '/DMO/I_Overall_Status_VH',
                                                 element: 'OverallStatus' } }]
  OverallStatus;

  @UI.hidden: true
  OverallStatusText;
  
  @UI.hidden: true
  LastChangedAt;
  
  @UI.hidden: true
  LocalLastChangedAt;


}
